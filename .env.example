N8N_URL=https://twoj-n8n.example.com
N8N_API_KEY=twoj-klucz-api

# Opcjonalnie: JSON mapujący nazwę DataTable → ścieżkę webhooka n8n (UUID).
# Backend trzyma sekret, przeglądarka nigdy nie widzi ścieżki.
# Po wciśnięciu przycisku "n8n webhook" w toolbarze, dashboard woła backend,
# który przekazuje żądanie do n8n; po odpowiedzi tabela odświeża się sama.
# Przykład:
#   WEBHOOKS={"ang_anki":"0e0c3430-0edb-4e78-bf24-faaeb99f3b48"}
WEBHOOKS={}